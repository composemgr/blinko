# Blinko - Self-hosted note-taking tool
# Copy to app.env and fill in your values

# Timezone
TZ=America/New_York

# Hostname
BASE_HOST_NAME=$HOSTNAME

# Database credentials (PostgreSQL admin user)
DB_CREATE_DATABASE_NAME=postgres
DB_ADMIN_USER=postgres
DB_ADMIN_PASS=changeme_admin_password

# NextAuth encryption secret (must be at least 32 characters)
ENCRYPTION_KEY=changeme_encryption_key_min_32_chars
